{
  "name": "npm-harness",
  "version": "0.1.0",
  "description": "npm-native agent-ready repository harness (init + durable SQLite)",
  "type": "module",
  "bin": {
    "harness": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "templates",
    "migrations",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"import('node:fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\"",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "harness": "node --import tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "keywords": [
    "harness",
    "agents",
    "cli",
    "sqlite"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
